{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "keyVault": {
            "type": "string",
            "defaultValue": "[concat('secscankv',toLower(uniqueString(resourceGroup().id)))]",
            "metadata": {
                "description": "The key vault name."
            }
        },
        "location": {
            "type": "string",
            "defaultValue": "[resourceGroup().location]",
            "metadata": {
                "description": "The location in which the Azure resources should be deployed."
            }
        },
        "objectId": {
            "type": "string",
            "defaultValue": "",
            "metadata": {
                "description": "The object ID to grant GET access to certificates and secrets."
            }
        }
    },
    "variables": {
        "keyVaultSecretsUserRoleId": "4633458b-17de-408a-b874-0445c86b69e6",
        "keyVaultReaderRoleId": "21090545-7ca7-4776-b22c-e363652d74d2"
    },
    "resources": [
        {
            "type": "Microsoft.KeyVault/vaults",
            "apiVersion": "2023-02-01",
            "name": "[parameters('keyVault')]",
            "location": "[parameters('location')]",
            "properties": {
                "sku": {
                    "family": "A",
                    "name": "standard"
                },
                "tenantId": "[subscription().tenantId]",
                "enabledForDeployment": true,
                "enabledForDiskEncryption": true,
                "enabledForTemplateDeployment": true,
                "enableSoftDelete": true,
                "enableRbacAuthorization": true,
                "accessPolicies": []
            }
        },
        {
            "condition": "[not(empty(parameters('objectId')))]",
            "type": "Microsoft.Authorization/roleAssignments",
            "apiVersion": "2022-04-01",
            "scope": "[concat('Microsoft.KeyVault/vaults/', parameters('keyVault'))]",
            "name": "[guid(resourceId('Microsoft.KeyVault/vaults', parameters('keyVault')), parameters('objectId'), variables('keyVaultSecretsUserRoleId'))]",
            "dependsOn": ["[resourceId('Microsoft.KeyVault/vaults', parameters('keyVault'))]"],
            "properties": {
                "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('keyVaultSecretsUserRoleId'))]",
                "principalId": "[parameters('objectId')]"
            }
        },
        {
            "condition": "[not(empty(parameters('objectId')))]",
            "type": "Microsoft.Authorization/roleAssignments",
            "apiVersion": "2022-04-01",
            "scope": "[concat('Microsoft.KeyVault/vaults/', parameters('keyVault'))]",
            "name": "[guid(resourceId('Microsoft.KeyVault/vaults', parameters('keyVault')), parameters('objectId'), variables('keyVaultReaderRoleId'))]",
            "dependsOn": ["[resourceId('Microsoft.KeyVault/vaults', parameters('keyVault'))]"],
            "properties": {
                "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('keyVaultReaderRoleId'))]",
                "principalId": "[parameters('objectId')]"
            }
        }
    ]
}
